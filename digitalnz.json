{
  "id": "digitalnz-metadata",
  "name": "DigitalNZ",
  "version": "1.0.1",
  "description": "DigitalNZ metadata provider",
  "capabilities": {
    "search": true
  },
  "search": {
    "url": "https://api.digitalnz.org/v3/records.json",
    "method": "GET",
    "params": {
      "text": "{{query}}",
      "page": "{{page}}",
      "per_page": "{{limit}}"
    },
    "responsePath": "results",
    "map": {
      "id": "id",
      "title": "title",
      "author": "creator",
      "description": "description",
      "cover": "thumbnail_url",
      "publisher": "content_partner",
      "date": "date",
      "url": "source_url"
    }
  }
}
